//Saladrex TdG                                                                                              //
COPY_EXISTING ~GORSAL.cre~ ~override/GORSAL.cre~                                                            //
  ADD_CRE_ITEM ~SCALER~ #0 #0 #0 ~IDENTIFIED~ ~INV15~                                                       //
