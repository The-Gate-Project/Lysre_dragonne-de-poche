	// Variable used by FUNCTION GW_FIND_DLG_RESPONSE_STRING to find after which transition NPC will be recalled by Fate Spirit.
			OUTER_SET fatesp_string = 65012  // Korgan = @65012  = ~J'ai besoin de Korgan, le guerrier berserker nain.~

ACTION_IF GAME_IS ~eet~ BEGIN
  INCLUDE ~EET/other/EET_functions.tph~
  LAF ~EET_NPC_TRANSITION~
    INT_VAR
      type = 2
      default_ToB = 1
      clean_ToB = 1
    STR_VAR
      dv = "CKLysre"
      override_SoA = "CKLysreS"
//      override_ToB = "CKLys25S"
      dialog_ToB = "CKLysr25"
      cre_ToB = "CKLysr25"
      traFile = EVAL "weidu_external/Lysre/Languages/autotra/%LANGUAGE%/SETUP-Lysre.tra"
      string = "@49"
      stringPosDV = "Mkhiin"
      clean_ToB_DV = "Lysre"
  END
END ELSE BEGIN
		INCLUDE ~Lysre/lib/gw_dlg_functions.tpa~
  COMPILE EVALUATE_BUFFER ~Lysre/Dialogue/FATESP.d~ USING ~weidu_external/Lysre/Languages/autotra/%LANGUAGE%/SETUP-Lysre.tra~
END

