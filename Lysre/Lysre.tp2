//Ajout des ecailles manquantes aux dragons///////////////////////////////////////////////////////////////////
//Irenicus                                                                                                  //
COPY_EXISTING ~DRAGBLAC.cre~ ~override/DRAGBLAC.cre~                                                        //
  ADD_CRE_ITEM ~SCALEB~ #0 #0 #0 ~IDENTIFIED~ ~INV15~                                                       //
