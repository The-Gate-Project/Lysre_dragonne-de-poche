BACKUP ~Lysre/Backup~
AUTHOR ~Mod NPC : Lysre
Auteur : Klare.
Avec l'aide de Deratiseur de la Couronne de Cuivre
Avec le doublage de Zyl de la Couronne de Cuivre
Sur la base du mod Brawen NPC~

VERSION ~1.0~
//Bloc de controle 1  //////////////////////////////////////
ALWAYS                                                    //
  ACTION_IF NOT VARIABLE_IS_SET bg2_chapter BEGIN         //
    ACTION_IF GAME_IS ~eet~ BEGIN                         //
      OUTER_SET bg2_chapter = 12                          //
    END ELSE BEGIN                                        //
      OUTER_SET bg2_chapter = 0                           //
    END                                                   //
    OUTER_FOR (i=1; i<=10; i=i+1) BEGIN                   //
      OUTER_SET bg2_chapter = bg2_chapter + 1             //
      OUTER_SPRINT name_source ~bg2_chapter_%i%~          //
      OUTER_SET EVAL ~%name_source%~ = bg2_chapter        //
    END                                                   //
  END                                                     //
END                                                       //
//Fin du Bloc de controle 1/////////////////////////////////

//Bloc de controle 2 : neccessaire au Kit///////////////////
ALWAYS                                                    //
	INCLUDE ~Lysre/Kit/fl#add_kit_ee.tpa~             //
END                                                       //
////////////////////////////////////////////////////////////

//Langues et traductions possibles  ////////////////////////////////////
AUTO_TRA ~Lysre/%s~                                                   //
LANGUAGE ~French~  ~French~  ~Lysre/French/Setup-Lysre.tra~           //
// Fin bloc langues  ///////////////////////////////////////////////////


////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
BEGIN       @0                                                                                                                    //
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ACTION_IF GAME_IS ~BG2EE eet~ BEGIN
LOAD_TRA ~Lysre/%LANGUAGE%/Setup-Lysre-EE.tra~
ADD_JOURNAL @24 USING ~Lysre/%LANGUAGE%/CKLysre.tra~
END

APPEND ~STATE.IDS~ ~0x80101FEF CD_STATE_NOTVALID~
UNLESS ~CD_STATE_NOTVALID~

