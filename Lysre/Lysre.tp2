EXTEND_TOP ~AR6200.bcs~ ~Lysre/Scripts/AR6200.baf~//Apparition du NPC dans TOB (inutile)

COPY ~Lysre/Epilogue/CKLysrzz.2da~ ~override/CKLysr01.2da~
