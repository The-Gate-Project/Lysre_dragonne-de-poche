BACKUP ~weidu_external/Lysre/Backup~

AUTHOR ~Mod NPC : Lysre
Auteur : Klare.
Avec l'aide de Deratiseur de la Couronne de Cuivre
Avec le doublage de Zyl de la Couronne de Cuivre
Sur la base du mod Brawen NPC~


// README ~~

VERSION ~1.3~

///////////////////////////////////////////////////////////

ALWAYS

//Bloc de controle 1///////////////////////////////////////

	ACTION_IF GAME_IS ~eet~ BEGIN
			OUTER_SET bg2_chapter = 12
	END ELSE BEGIN
			OUTER_SET bg2_chapter = 0
	END
			OUTER_FOR (i = 1 ; i <= 10 ; ++i) BEGIN
			OUTER_SET bg2_chapter = bg2_chapter + 1
			OUTER_SPRINT name_source ~bg2_chapter_%i%~
			OUTER_SET EVAL ~%name_source%~ = bg2_chapter
	END

//Fin du Bloc de controle 1 ///////////////////////////////

	DEFINE_ACTION_FUNCTION autotra_workaround BEGIN
	COPY ~Lysre/Languages/French~				~weidu_external/Lysre/Languages/autotra/%LANGUAGE%~
	COPY ~Lysre/Languages/%LANGUAGE%~				~weidu_external/Lysre/Languages/autotra/%LANGUAGE%~
	END

	LAF autotra_workaround END

	ACTION_IF GAME_IS ~tob bgt~ BEGIN

//			ACTION_DEFINE_ARRAY CK_noconvert BEGIN END

		ACTION_DEFINE_ARRAY CK_reload BEGIN Setup-Lysre END
			LAF HANDLE_CHARSETS
				INT_VAR
				infer_charsets = 1
				from_utf8      = 1
				STR_VAR
				tra_path = EVAL ~weidu_external/Lysre/Languages/autotra~
				out_path = EVAL ~weidu_external/Lysre/Languages/autotra~
				iconv_path = ~Lysre/Languages/autotra/iconv~
//				noconvert_array = CK_noconvert
				reload_array = CK_reload
			END

	END // GAME_IS ~tob bgt~

//Bloc de controle 2 : neccessaire au Kit /////////////////

	INCLUDE ~Lysre/Kit/a7#add_kit_ex.tpa~

//Fin du Bloc de controle 2 ///////////////////////////////

END // ALWAYS

///////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////
//Langues et traductions possibles  ///////////////////////

AUTO_TRA ~weidu_external/Lysre/Languages/autotra/%s~

LANGUAGE ~French~
