END

APPEND ~interdia.2da~ ~CKLysre       BCKLysre       BCKLys25~
UNLESS ~CKLysre~

APPEND ~pdialog.2da~ ~CKLysre        CKLysreP             CKLysreJ            CKLysreD             CKLys25P             CKLys25J             CKLys25D       CKLys25S~
UNLESS ~CKLysre~

LAF HANDLE_AUDIO END

ACTION_IF GAME_IS ~eet~ BEGIN
  INCLUDE ~EET/other/EET_functions.tph~
  LAF ~EET_NPC_TRANSITION~
    INT_VAR
      type = 2
      default_ToB = 1
      clean_ToB = 1
    STR_VAR
      dv = "CKLysre"
      override_SoA = "CKLysreS"
      override_ToB = "CKLys25S"
      dialog_ToB = "CKLysr25"
      cre_ToB = "CKLysr25"
      traFile = EVAL "Lysre/%LANGUAGE%/CKLys25J.tra"
      string = "@8" //Bring me Lysre
      stringPosDV = "Viconia"
      clean_ToB_DV = "Lysre"
  END
END ELSE BEGIN
  COMPILE ~Lysre/Dialogue/FATESP.d~ USING ~Lysre/%LANGUAGE%/CKLys25J.tra~
END

