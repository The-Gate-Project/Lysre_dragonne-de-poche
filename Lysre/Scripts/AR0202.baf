//TEMPLE DE LOEIL AVEUGLE

// Generation de la pretresse emprisonnÈe ///////////////
IF                                                     //
Global("CKPretressespawn","AR0202",0)  
Global("CKquete1","Global",4)                          //
THEN                                                   //
RESPONSE #100                                          //
SetGlobal("CKPretressespawn","AR0202",1)               //
CreateCreature("CKFelic2",[2220.1576],13)              //
END                                                    //
