//////////////////////////////////////////////////////////////////////////////////////////
//Equilibrer l'xp ////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
// 800000
IF
InParty(Myself)
Global("CKLysreExperienceSet","GLOBAL",0)
XPGT(Player1,600000)
XPLT(Player1,1000001)
THEN
RESPONSE #100
SetGlobal("CKLysreExperienceSet","GLOBAL",1)
AddXPObject("CKLysre",400000)
END

// 1200000
IF
InParty(Myself)
Global("CKLysreExperienceSet","GLOBAL",0)
XPGT(Player1,1000000)
XPLT(Player1,1400001)
THEN
RESPONSE #100
SetGlobal("CKLysreExperienceSet","GLOBAL",1)
AddXPObject("CKLysre",800000)
END

// 1600000
IF
InParty(Myself)
Global("CKLysreExperienceSet","GLOBAL",0)
XPGT(Player1,1400000)
XPLT(Player1,1800001)
THEN
RESPONSE #100
SetGlobal("CKLysreExperienceSet","GLOBAL",1)
AddXPObject("CKLysre",1200000)
END

// 2000000
IF
InParty(Myself)
Global("CKLysreExperienceSet","GLOBAL",0)
XPGT(Player1,1800000)
THEN
RESPONSE #100
SetGlobal("CKLysreExperienceSet","GLOBAL",1)
AddXPObject("CKLysre",1600000)
END

// Hotkey fixer
IF
	HotKey(K)
	InParty("CKLysre")
	!ActuallyInCombat()
THEN
	RESPONSE #100
		StartCutSceneMode()
		StartCutScene("CKLysreF")
END
