//Ecaille dragon blanc : COMPON18.ITM
//Ecaille dragon bleu : COMPON19.ITM
//Ecaille dragon argent : OHDSCALE.ITM
//Coeur de Bodhi : MISCBP.ITM

////////////////////////////////////////////////////////////////////////////
//Lancer le premier dialogue avec le joueur/////////////////////////////////
////////////////////////////////////////////////////////////////////////////
IF
	Global("CKLysreintro","LOCALS",0)
	Global("CKSummon_ToB","LOCALS",0)
	OR(2)
		Global("CKLysreSpawn","GLOBAL",1)
		AreaCheck("AR4500")
THEN
	RESPONSE #100
		StartDialogueNoSet([PC])
END

////////////////////////////////////////////////////////////////////////////
//Tuer le NPC et relanger le dialogue avec le joueur////////////////////////
////////////////////////////////////////////////////////////////////////////
IF
	Global("CKLysreintro","LOCALS",1)
	Global("CKLysreSpawn","GLOBAL",1)
THEN
	RESPONSE #100
		ClearAllActions()
		StartCutSceneMode()
		CutSceneId(Player1)
//		Spell("CKMORTIN",WIZARD_MELF_ACID_ARROW)
		ActionOverride("CKLysre",ApplySpell("CKMORTIN",WIZARD_MELF_ACID_ARROW))
		Wait(1)
		Kill("CKMORTIN")
		Wait(1)
		EndCutSceneMode()
		StartDialogueNoSet([PC])
END

////////////////////////////////////////////////////////////////////////////
//Lancer la quete propre au NPC  ///////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////
IF
	Dead("UnseeingEye")  // L'oeil aveugle a été tué, c'est le CRE de l'amulette
	Dead("GAAL")  // Le pretre a été tué.
	PartyRested()  // Le groupe s'est reposé, ce qui veut dire que la zone a été nettoyée, et que le NPC a pu avoir son message Divin.
	Global("CKquete1","GLOBAL",0)  // Variable qui lance la quete
	!ActuallyInCombat()
	!StateCheck("CKLysre",CD_STATE_NOTVALID)
THEN
	RESPONSE #100
		SetGlobal("CKquete1","GLOBAL",1) //La quete est lancée
		StartDialogueNoSet([PC])
END

IF
	PartyRested()  // Le groupe s'est reposé, ce qui veut dire que la zone a été nettoyée, et que le NPC a pu avoir son message Divin.
	Global("CKquete1","GLOBAL",6)  // Variable qui lance la quete
THEN
	RESPONSE #100
		SetGlobal("CKquete1","GLOBAL",7) //La quete est lancée
END

// 0 : Quete non lancée
// 1 : Quete lancée
// 2 : Quete proposée par Lysre
// 3 : La pretresse est trouvé // Il faut lui amener les clefs de la prison.
// 4 : La apparait dans le temple.
// 5 : elle a fait le dialogue d'intro et lancé la quete de la baguette
// 6 : Baguette donnée a la pretresse, elle lance la partie suivante de la quete
// 7 : Kobolds a l'entrée du temple // L'antipaladin est arrivée a la CdC
// 8 : Le paladin est arrivé dans le temple, ainsi que les acolytes

//////////////////////////////////////////////////////////////////////////
//Produire acide//////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////
IF
	Global("CKacide","GLOBAL",0)  // Variable qui lance le dialogue
THEN
	RESPONSE #100
		SetGlobal("CKacide","GLOBAL",1) //<-- Action
END

IF
	Global("CKacide","GLOBAL",2)
	PartyRested()
	!StateCheck("CKLysre",CD_STATE_NOTVALID)
THEN
	RESPONSE #100
		SetGlobal("CKacide","GLOBAL",1) //<-- Action
END

