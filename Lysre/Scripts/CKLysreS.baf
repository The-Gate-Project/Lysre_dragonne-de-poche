//Ecaille dragon rouge////////////////////////////////////////////////////////////////////
//Ecailles Firkarg
IF
	PartyHasItem("SCALER")
//	AreaCheck("AR1203")
	Global("CKecailleR","GLOBAL",0)  // Variable qui lance le dialogue
	!ActuallyInCombat()
	!StateCheck("CKLysre",CD_STATE_NOTVALID)
	!StateCheck(Player1,CD_STATE_NOTVALID)
THEN
	RESPONSE #100
		SetGlobal("CKecailleR","GLOBAL",1)// 1=le dialogue est lancé
		StartDialogueNoSet(Player1) //<-- Action
END
