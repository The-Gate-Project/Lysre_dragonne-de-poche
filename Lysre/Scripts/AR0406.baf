//Couronne de cuivre

// Generation de la paladine pour tiamat /////////////
IF
	Global("CKPaladine","MYAREA",0)
	Global("CKquete1","Global",7)
THEN
	RESPONSE #100
		SetGlobal("CKPaladine","MYAREA",1)
		CreateCreature("CKvarsco",[1624.1750],13)
		Continue()
END
